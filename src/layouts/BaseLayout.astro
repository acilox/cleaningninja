---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces/opsz.css';
import '@fontsource-variable/fraunces/opsz-italic.css';
import '../styles/global.css';
import { site, faqs } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CleaningNinja | Professional Home & Commercial Cleaning Across Australia',
  description = 'CleaningNinja — vetted, insured cleaners for homes, offices and end-of-lease bond cleans across Sydney, Melbourne, Brisbane, Adelaide & Perth. Book in 60 seconds. 100% bond-back guarantee.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // no trailing slash
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// JSON-LD — CleaningService (specific LocalBusiness subtype) + FAQPage.
const businessLd = {
  '@context': 'https://schema.org',
  '@type': 'CleaningService',
  '@id': `${Astro.site}#business`,
  name: site.fullName,
  description,
  url: canonical,
  image: `${base}/og.svg`,
  telephone: `+${site.waNumber}`,
  email: site.email,
  priceRange: '$$',
  areaServed: ['Sydney', 'Melbourne', 'Brisbane', 'Adelaide', 'Perth'].map((name) => ({
    '@type': 'City',
    name,
  })),
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'AU',
    addressRegion: site.region,
    addressLocality: site.city,
  },
  makesOffer: [
    'Regular house cleaning',
    'End-of-lease bond cleaning',
    'Commercial & office cleaning',
    'Carpet & upholstery cleaning',
    'Window cleaning',
    'Spring & deep cleaning',
  ].map((name) => ({ '@type': 'Offer', itemOffered: { '@type': 'Service', name } })),
  sameAs: [site.socials.instagram, site.socials.facebook],
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Unlisted while in testing — remove noindex at go-live/handoff. -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.fullName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${base}/og.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${base}/og.svg`} />

    <meta name="theme-color" content="#06080c" />
    <script type="application/ld+json" set:html={JSON.stringify(businessLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    <!-- Flag JS early so reveal styles only hide content when JS can un-hide it. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class="grain">
    <div id="scrollBar" aria-hidden="true"></div>

    <!-- Custom context-aware cursor (pointer:fine only; native cursor is the fallback) -->
    <div id="cursor" aria-hidden="true"><span class="clabel"></span></div>
    <div id="cursorDot" aria-hidden="true"></div>

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:m-3 focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-black focus:shadow-lg"
      >Skip to content</a
    >

    <slot />

    <!-- ── CDN libraries (deferred; the site is fully readable without them) ── -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js" defer></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js" defer></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js" defer></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js" defer></script>

    <script is:inline>
      window.addEventListener('load', () => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const gsap = window.gsap;
        const ScrollTrigger = window.ScrollTrigger;
        const SplitText = window.SplitText;
        const hasGSAP = !!(gsap && ScrollTrigger);

        if (hasGSAP) {
          gsap.registerPlugin(ScrollTrigger, ...(SplitText ? [SplitText] : []));
          ScrollTrigger.config({ ignoreMobileResize: true });
        }

        // ── Lenis smooth scroll (drive via gsap.ticker when GSAP present) ──
        if (typeof window.Lenis !== 'undefined' && !reduce) {
          const lenis = new window.Lenis({ duration: 1.1, smoothWheel: true });
          window.__lenis = lenis;
          if (hasGSAP) {
            lenis.on('scroll', ScrollTrigger.update);
            gsap.ticker.add((t) => lenis.raf(t * 1000));
            gsap.ticker.lagSmoothing(0);
          } else {
            const raf = (time) => { lenis.raf(time); requestAnimationFrame(raf); };
            requestAnimationFrame(raf);
          }
        }

        // ── Hero frame clip-path load wipe (pure CSS transition; no CDN needed) ──
        const heroFrame = document.querySelector('.hero-frame');
        if (heroFrame) requestAnimationFrame(() => requestAnimationFrame(() => heroFrame.classList.add('wiped')));

        // ── Reveal-on-scroll via IntersectionObserver (no CDN dependency) ──
        const revealEls = document.querySelectorAll(
          '[data-reveal],[data-reveal-left],[data-reveal-right],[data-reveal-group]'
        );
        if (reduce || !('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-in'));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
          );
          revealEls.forEach((el) => io.observe(el));
        }

        // ══════════════════ GSAP-enhanced storytelling (guarded) ══════════════════
        if (hasGSAP && !reduce) {
          // Hero parallax — framed photo, floating cards and copy drift at different speeds.
          if (document.querySelector('.hero-img')) {
            gsap.to('.hero-img', { yPercent: 12, ease: 'none',
              scrollTrigger: { trigger: '#top', start: 'top top', end: 'bottom top', scrub: true } });
          }
          if (document.querySelector('.hero-fc--rating')) {
            gsap.to('.hero-fc--rating', { yPercent: -55, ease: 'none',
              scrollTrigger: { trigger: '#top', start: 'top top', end: 'bottom top', scrub: true } });
            gsap.to('.hero-fc--guarantee', { yPercent: 40, ease: 'none',
              scrollTrigger: { trigger: '#top', start: 'top top', end: 'bottom top', scrub: true } });
          }
          if (document.querySelector('#heroCopy')) {
            gsap.to('#heroCopy', { yPercent: -6, opacity: 0.45, ease: 'none',
              scrollTrigger: { trigger: '#top', start: 'top top', end: 'bottom top', scrub: true } });
          }

          // Per-word masked heading reveals on [data-split] section titles + hero line reveal.
          if (SplitText) {
            // Hide the hero title only now that GSAP is confirmed present (CSS .rise is the no-CDN fallback).
            const heroTitle = document.querySelector('#heroTitle');
            if (heroTitle) { heroTitle.classList.remove('rise'); gsap.set(heroTitle, { autoAlpha: 0 }); }
            document.fonts.ready.then(() => {
              if (heroTitle) {
                gsap.set(heroTitle, { autoAlpha: 1 });
                const hs = SplitText.create(heroTitle, { type: 'lines', mask: 'lines', linesClass: 'hero-line' });
                gsap.from(hs.lines, { yPercent: 118, duration: 1, stagger: 0.14, ease: 'expo.out' });
              }
              document.querySelectorAll('[data-split]').forEach((el) => {
                const split = SplitText.create(el, { type: 'words', mask: 'words' });
                gsap.from(split.words, {
                  yPercent: 115, opacity: 0, duration: 0.8, ease: 'expo.out', stagger: 0.035,
                  scrollTrigger: { trigger: el, start: 'top 88%' },
                });
              });
              ScrollTrigger.refresh();
            });
          }

          // Services — sticky image swap: activate the photo for the centred service.
          const svcItems = gsap.utils.toArray('.svc-item');
          const svcPhotos = document.querySelectorAll('.svc-photo');
          if (svcItems.length && svcPhotos.length) {
            const setActive = (i) => {
              svcPhotos.forEach((p, idx) => p.classList.toggle('active', idx === i));
              svcItems.forEach((it, idx) => it.setAttribute('data-active', String(idx === i)));
            };
            setActive(0);
            svcItems.forEach((item, i) => {
              ScrollTrigger.create({
                trigger: item, start: 'top center', end: 'bottom center',
                onToggle: (self) => self.isActive && setActive(i),
              });
            });
          }

          // How It Works — pinned scroll story (desktop only; mobile stays stacked).
          const mm = gsap.matchMedia();
          mm.add('(min-width: 900px)', () => {
            const how = document.querySelector('#how .how-stage');
            const steps = gsap.utils.toArray('#how .how-step');
            const ticks = gsap.utils.toArray('#how .how-tick');
            if (!how || steps.length < 2) return;
            how.classList.add('is-pinned');
            gsap.set(steps, { autoAlpha: 0, y: 50 });
            gsap.set(steps[0], { autoAlpha: 1, y: 0 });
            const tl = gsap.timeline({
              scrollTrigger: { trigger: '#how', start: 'top top', end: '+=220%', scrub: 1, pin: how, anticipatePin: 1 },
            });
            steps.forEach((step, i) => {
              if (i === 0) return;
              tl.to(steps[i - 1], { autoAlpha: 0, y: -40, duration: 0.4 })
                .to(step, { autoAlpha: 1, y: 0, duration: 0.5 }, '<0.1');
              if (ticks[i - 1]) tl.to(ticks[i - 1], { color: 'var(--color-accent)', duration: 0.2 }, '<');
            });
            if (ticks[steps.length - 1]) tl.to(ticks[steps.length - 1], { color: 'var(--color-accent)', duration: 0.2 });
            return () => {
              if (tl.scrollTrigger) tl.scrollTrigger.kill();
              tl.kill();
              how.classList.remove('is-pinned');
              gsap.set(steps, { clearProps: 'all' });
            };
          });

          // Recompute positions once images have decoded.
          ScrollTrigger.refresh();
          window.addEventListener('resize', () => ScrollTrigger.refresh());
        }

        // ── Count-up for stat numbers (IO-driven; no CDN) ──
        (function () {
          const nums = document.querySelectorAll('[data-count]');
          if (!nums.length) return;
          const fmt = (v, decimals) =>
            v.toLocaleString('en-AU', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
          const run = (el) => {
            const target = parseFloat(el.getAttribute('data-count'));
            const prefix = el.getAttribute('data-prefix') || '';
            const suffix = el.getAttribute('data-suffix') || '';
            const decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);
            if (reduce) { el.textContent = prefix + fmt(target, decimals) + suffix; return; }
            const dur = 1600, start = performance.now();
            const step = (now) => {
              const p = Math.min((now - start) / dur, 1);
              const eased = 1 - Math.pow(1 - p, 3);
              el.textContent = prefix + fmt(target * eased, decimals) + suffix;
              if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          };
          if (!('IntersectionObserver' in window)) { nums.forEach(run); return; }
          const io = new IntersectionObserver((entries) => {
            entries.forEach((e) => { if (e.isIntersecting) { run(e.target); io.unobserve(e.target); } });
          }, { threshold: 0.6 });
          nums.forEach((n) => io.observe(n));
        })();

        // ── Custom context-aware cursor (pointer:fine only) ──
        (function () {
          if (reduce || !window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
          const ring = document.getElementById('cursor');
          const dot = document.getElementById('cursorDot');
          if (!ring || !dot) return;
          document.documentElement.classList.add('cursor-on');
          const label = ring.querySelector('.clabel');
          let rx = innerWidth / 2, ry = innerHeight / 2, dx = rx, dy = ry, mx = rx, my = ry;
          // Keep the cursor hidden until the pointer actually moves (no dot parked mid-screen on load).
          ring.style.opacity = '0'; dot.style.opacity = '0';
          let shown = false;
          window.addEventListener('pointermove', (e) => {
            mx = e.clientX; my = e.clientY;
            if (!shown) { shown = true; ring.style.opacity = '1'; dot.style.opacity = '1'; }
          }, { passive: true });
          const loop = () => {
            dx += (mx - dx) * 0.9; dy += (my - dy) * 0.9;
            rx += (mx - rx) * 0.18; ry += (my - ry) * 0.18;
            dot.style.transform = `translate(${dx}px, ${dy}px)`;
            ring.style.transform = `translate(${rx}px, ${ry}px)`;
            requestAnimationFrame(loop);
          };
          requestAnimationFrame(loop);
          const setLabel = (t) => { if (label) label.textContent = t; ring.classList.toggle('is-label', !!t); };
          document.querySelectorAll('a, button, [data-cursor], .ba, [role="slider"]').forEach((el) => {
            const custom = el.getAttribute('data-cursor');
            el.addEventListener('pointerenter', () => { ring.classList.add('is-hover'); setLabel(custom || ''); });
            el.addEventListener('pointerleave', () => { ring.classList.remove('is-hover'); setLabel(''); });
          });
        })();

        // ── 3D tilt cards (hover:hover only) ──
        (function () {
          if (reduce || !window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
          document.querySelectorAll('[data-tilt]').forEach((card) => {
            let raf = 0;
            const move = (e) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width, py = (e.clientY - r.top) / r.height;
              const rotY = (px - 0.5) * 10, rotX = (0.5 - py) * 10;
              card.style.setProperty('--gx', px * 100 + '%');
              card.style.setProperty('--gy', py * 100 + '%');
              cancelAnimationFrame(raf);
              raf = requestAnimationFrame(() => {
                card.style.transform = `perspective(900px) rotateX(${rotX}deg) rotateY(${rotY}deg)`;
              });
            };
            card.addEventListener('pointermove', move);
            card.addEventListener('pointerleave', () => { cancelAnimationFrame(raf); card.style.transform = ''; });
          });
        })();

        // ── Magnetic elements (pointer only) — lerp + elastic spring-back if GSAP ──
        (function () {
          if (reduce || !window.matchMedia('(pointer:fine)').matches) return;
          document.querySelectorAll('[data-magnetic]').forEach((el) => {
            const label = el.querySelector('.mag-label');
            el.addEventListener('pointermove', (e) => {
              const r = el.getBoundingClientRect();
              const x = e.clientX - r.left - r.width / 2;
              const y = e.clientY - r.top - r.height / 2;
              el.style.transform = `translate(${x * 0.18}px, ${y * 0.3}px)`;
              if (label) label.style.transform = `translate(${x * 0.08}px, ${y * 0.12}px)`;
            });
            el.addEventListener('pointerleave', () => {
              if (hasGSAP) {
                gsap.to(el, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1,0.3)' });
                if (label) gsap.to(label, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1,0.3)' });
              } else {
                el.style.transform = '';
                if (label) label.style.transform = '';
              }
            });
          });
        })();
      });

      // ── Scroll progress bar + nav state + sticky CTA (no lib needed) ──
      (function () {
        const bar = document.getElementById('scrollBar');
        const nav = document.getElementById('siteNav');
        const sticky = document.getElementById('stickyBook');
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
          if (bar) bar.style.width = pct + '%';
          if (nav) nav.classList.toggle('scrolled', h.scrollTop > 12);
          if (sticky) {
            const nearBottom = max - h.scrollTop < 300;
            sticky.classList.toggle('show', h.scrollTop > 620 && !nearBottom);
          }
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();

      // ── Mobile nav toggle ──
      (function () {
        const btn = document.getElementById('navToggle');
        const menu = document.getElementById('mobileMenu');
        if (!btn || !menu) return;
        btn.addEventListener('click', () => {
          const open = menu.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', String(open));
        });
        menu.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => menu.classList.add('hidden'))
        );
      })();

      // ── FAQ accordion ──
      (function () {
        document.querySelectorAll('.faq-item').forEach((item) => {
          const q = item.querySelector('.faq-q');
          if (!q) return;
          q.addEventListener('click', () => {
            const open = item.getAttribute('data-open') === 'true';
            item.setAttribute('data-open', String(!open));
            q.setAttribute('aria-expanded', String(!open));
          });
        });
      })();
    </script>
  </body>
</html>
