---
import { site } from '../data/site';
const year = new Date().getFullYear();
const links = [
  { href: '#services', label: 'Services' },
  { href: '#how', label: 'How it works' },
  { href: '#coverage', label: 'Coverage' },
  { href: '#reviews', label: 'Reviews' },
  { href: '#faq', label: 'FAQ' },
  { href: '#quote', label: 'Free quote' },
];
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-bg-2)]">
  <div class="container-x py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <!-- Brand -->
      <div>
        <a href="#top" class="flex items-center gap-2.5">
          <svg width="28" height="28" viewBox="0 0 64 64" aria-hidden="true">
            <defs><linearGradient id="fg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#00D4AA"/><stop offset="1" stop-color="#00A88A"/></linearGradient></defs>
            <path d="M32 12c-6 8-10 13-10 18a10 10 0 0 0 20 0c0-5-4-10-10-18z" fill="url(#fg)"/>
            <circle cx="28" cy="30" r="2.6" fill="#EDF2F7" opacity="0.85"/>
          </svg>
          <span class="wordmark text-lg text-white">Cleaning<span class="text-[var(--color-accent)]">Ninja</span></span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-muted-2)]">
          {site.tagline} Professional, vetted, insured cleaners for homes and businesses across Australia.
        </p>
        <div class="mt-5 flex gap-3">
          <a href={site.socials.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--color-line)] text-[var(--color-muted-2)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.socials.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--color-line)] text-[var(--color-muted-2)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h3v7h3v-7h3l1-3h-4v-2c0-.6.4-1 1-1z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Explore</h3>
        <ul class="mt-4 space-y-2.5">
          {links.map((l) => <li><a href={l.href} class="text-sm text-[var(--color-muted-2)] transition hover:text-[var(--color-accent)]">{l.label}</a></li>)}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Get in touch</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-muted-2)]">
          <li><a href={site.phoneHref} class="transition hover:text-[var(--color-accent)]">{site.phone}</a></li>
          <li><a href={`mailto:${site.email}`} class="transition hover:text-[var(--color-accent)]">{site.email}</a></li>
          <li>{site.serviceArea}</li>
          <li class="text-[var(--color-muted)]">{site.hours}</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-[var(--color-line)] pt-6 text-xs text-[var(--color-muted)] sm:flex-row">
      <p>© {year} {site.fullName}. All rights reserved.</p>
      <p>Fully insured · Police-checked · ABN placeholder</p>
    </div>
  </div>
</footer>
