---
import { steps } from '../data/site';
const checklist = [
  'Kitchen, benches & splashbacks',
  'Oven, cooktop & rangehood',
  'Bathrooms, tiles & glass',
  'Floors vacuumed & mopped',
  'Skirting, sills & switches',
];
---

<section id="how" class="section bg-[var(--color-bg-2)]">
  <div class="container-x">
    <div class="how-stage grid items-center gap-12 lg:min-h-[78vh] lg:grid-cols-[0.85fr_1.15fr]">
      <!-- Left: intro + progress rail -->
      <div>
        <span class="eyebrow">How it works</span>
        <h2 class="display-2 mt-4" data-split>Booked in 60 seconds.<br />Done to a <em>standard</em>.</h2>
        <ol class="mt-9 space-y-4">
          {steps.map((s, i) => (
            <li class={`how-tick flex items-center gap-3 text-lg font-semibold ${i === 0 ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]'}`}>
              <span class="grid h-8 w-8 place-items-center rounded-full border border-current text-sm">{i + 1}</span>
              {s.title}
            </li>
          ))}
        </ol>
      </div>

      <!-- Right: cross-faded step panels -->
      <div class="how-panels relative min-h-[22rem] lg:min-h-[26rem]">
        {steps.map((s, i) => (
          <article class={`how-step card grain relative overflow-hidden p-8 sm:p-10 ${i === 0 ? '' : 'mt-6'}`}>
            <div class="glow-spot"></div>
            <div class="relative">
              <span class="font-[var(--font-display)] text-6xl italic text-[var(--color-accent)]/70 sm:text-7xl">{s.n}</span>
              <h3 class="mt-4 text-2xl font-semibold text-white sm:text-3xl">{s.title}</h3>
              <p class="mt-4 max-w-md leading-relaxed text-[var(--color-muted-2)]">{s.body}</p>

              {i === 1 && (
                <ul class="mt-7 grid gap-2.5 sm:grid-cols-2">
                  {checklist.map((c) => (
                    <li class="flex items-center gap-2.5 text-sm text-[var(--color-text)]">
                      <svg class="text-[var(--color-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      {c}
                    </li>
                  ))}
                </ul>
              )}
              {i === 2 && (
                <div class="mt-7 inline-flex items-center gap-3 rounded-full border border-[var(--color-accent)]/40 bg-[var(--color-accent-soft)] px-5 py-2.5 text-sm font-semibold text-[var(--color-accent)]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
                  100% bond-back guarantee
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-14 text-center" data-reveal>
      <a href="#quote" data-magnetic data-cursor="Book" class="btn btn-primary"><span class="mag-label">Start my free quote</span></a>
    </div>
  </div>
</section>
