---
import { steps } from '../data/site';
---

<section id="how" class="section">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">How it works</span>
      <h2 class="display-2 mt-4">Booked in 60 seconds. Done to a standard.</h2>
    </div>

    <div class="relative mt-16">
      <!-- Animated connector line (desktop) -->
      <svg class="pointer-events-none absolute left-0 right-0 top-8 hidden h-2 w-full md:block" viewBox="0 0 100 2" preserveAspectRatio="none" aria-hidden="true">
        <line class="step-line" x1="8" y1="1" x2="92" y2="1" pathLength="1" />
        <line class="step-line--anim" x1="8" y1="1" x2="92" y2="1" pathLength="1" />
      </svg>

      <div class="grid gap-10 md:grid-cols-3" data-reveal-group>
        {steps.map((s) => (
          <div class="relative text-center">
            <div class="relative mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-line)] bg-[var(--color-surface)] text-lg font-extrabold text-[var(--color-accent)]">
              {s.n.replace('0', '')}
            </div>
            <h3 class="mt-6 text-xl font-bold text-white">{s.title}</h3>
            <p class="mx-auto mt-3 max-w-xs leading-relaxed text-[var(--color-muted-2)]">{s.body}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-14 text-center" data-reveal>
      <a href="#quote" data-magnetic class="btn btn-primary">Start my free quote</a>
    </div>
  </div>
</section>
