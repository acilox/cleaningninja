---
import { coverage, agentLogos } from '../data/site';
---

<section id="coverage" class="section overflow-hidden">
  <div class="glow-spot glow-spot--warm" aria-hidden="true"></div>
  <div class="container-x relative">
    <div class="grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div data-reveal-left>
        <span class="eyebrow">Where we clean</span>
        <h2 class="display-2 mt-4" data-split>Trusted across Australia’s <em>major cities</em></h2>
        <p class="lead mt-5">
          From CBD apartments to suburban family homes and city offices — our vetted crews cover the
          neighbourhoods below and everywhere in between.
        </p>
        <p class="mt-6 text-sm text-[var(--color-muted)]">
          Not sure if we reach your suburb? Ask in the quote form — we’ll confirm the same day.
        </p>
        <a href="#quote" class="btn btn-ghost mt-7">Check my suburb</a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2" data-reveal-group>
        {coverage.map((c) => (
          <div class="card p-6">
            <div class="flex items-center gap-2.5">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <h3 class="text-lg font-semibold text-white">{c.city}</h3>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {c.suburbs.map((s) => (
                <span class="rounded-full border border-[var(--color-line)] px-3 py-1 text-xs text-[var(--color-muted-2)]">{s}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Real-estate agents who approve our bond cleans -->
    <div class="mt-16 border-t border-[var(--color-line)] pt-10 text-center" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-muted)]">Bond cleans approved by leading agencies</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        {agentLogos.map((a) => (
          <span class="wordmark text-lg text-[var(--color-muted-2)] opacity-70 transition hover:opacity-100 sm:text-xl">{a}</span>
        ))}
      </div>
    </div>
  </div>
</section>

