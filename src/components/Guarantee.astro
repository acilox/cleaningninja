---
import { guarantee } from '../data/site';
---

<section id="guarantee" class="section overflow-hidden">
  <div class="glow-spot glow-spot--left" aria-hidden="true"></div>
  <div class="container-x relative">
    <div class="card grain relative overflow-hidden p-8 sm:p-14" data-reveal>
      <div class="mesh !inset-0 opacity-70" aria-hidden="true"></div>
      <div class="relative grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
        <div>
          <span class="eyebrow">{guarantee.eyebrow}</span>
          <h2 class="display-2 mt-4" data-split set:html={guarantee.title.replace('Bond-Back', '<em>Bond-Back</em>')} />
          <p class="lead mt-5 max-w-xl">{guarantee.lead}</p>
          <ul class="mt-7 space-y-3.5">
            {guarantee.points.map((p) => (
              <li class="flex items-start gap-3 text-[var(--color-text)]">
                <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                {p}
              </li>
            ))}
          </ul>
          <a href="#quote" data-magnetic data-cursor="Book" class="btn btn-primary mt-9">
            <span class="mag-label">Book a guaranteed clean</span>
          </a>
        </div>

        <!-- Seal / badge -->
        <div class="flex justify-center lg:justify-end" data-reveal-right>
          <div class="relative grid h-56 w-56 place-items-center rounded-full border border-[var(--color-accent)]/40 bg-[var(--color-accent-soft)]/40 text-center sm:h-64 sm:w-64">
            <span class="seal-ring pointer-events-none absolute inset-3 rounded-full border border-dashed border-[var(--color-accent)]/30"></span>
            <div class="px-6">
              <div class="stat-num text-[var(--color-accent)] !text-6xl">100<span class="text-3xl align-super">%</span></div>
              <p class="mt-1 font-[var(--font-display)] italic text-white">Bond-back</p>
              <p class="mt-2 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-muted-2)]">{guarantee.seal}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
