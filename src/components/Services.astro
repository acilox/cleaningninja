---
import { services, bookFor } from '../data/site';
---

<section id="services" class="section">
  <div class="glow-spot"></div>
  <div class="container-x relative">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">What we do</span>
      <h2 class="display-2 mt-4">Every kind of clean, one trusted crew</h2>
      <p class="lead mx-auto mt-4 max-w-xl">
        Hover any service to see what’s included. Fixed checklists, no surprises — just results you can see.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
      {services.map((s) => (
        <div class="flip h-[19rem]" tabindex="0">
          <div class="flip__inner">
            <!-- FRONT -->
            <article class="flip__face card p-7">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </div>
              <h3 class="mt-5 text-xl font-bold text-white">{s.name}</h3>
              <p class="mt-1 text-sm font-medium text-[var(--color-accent)]">{s.tag}</p>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted-2)]">{s.body}</p>
              <span class="mt-auto inline-flex items-center gap-1.5 pt-4 text-sm font-semibold text-[var(--color-muted)]">
                Hover for details
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </article>

            <!-- BACK -->
            <article class="flip__face flip__back card p-7" style="background: linear-gradient(160deg, var(--color-surface-2), var(--color-surface));">
              <h3 class="text-lg font-bold text-white">{s.name}</h3>
              <ul class="mt-4 space-y-3">
                {s.points.map((p) => (
                  <li class="flex items-start gap-2.5 text-sm text-[var(--color-text)]">
                    <svg class="mt-0.5 flex-shrink-0 text-[var(--color-accent)]" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {p}
                  </li>
                ))}
              </ul>
              <a href={bookFor(s.name)} target="_blank" rel="noopener" class="btn btn-primary mt-auto justify-center text-sm">Get a quote for this</a>
            </article>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
