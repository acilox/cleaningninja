---
import { Image } from 'astro:assets';
import { services, bookFor } from '../data/site';

import house from '../assets/service-house.jpg';
import bond from '../assets/service-bond-clean.jpg';
import commercial from '../assets/service-commercial.jpg';
import carpet from '../assets/service-carpet.jpg';
import windowImg from '../assets/service-window.jpg';
import deep from '../assets/service-deep-clean.jpg';

const imgMap: Record<string, ImageMetadata> = {
  'service-house': house,
  'service-bond-clean': bond,
  'service-commercial': commercial,
  'service-carpet': carpet,
  'service-window': windowImg,
  'service-deep-clean': deep,
};
---

<section id="services" class="section">
  <div class="glow-spot"></div>
  <div class="container-x relative">
    <div class="max-w-2xl" data-reveal>
      <span class="eyebrow">What we do</span>
      <h2 class="display-2 mt-4" data-split>Every kind of clean,<br />one <em>trusted</em> crew.</h2>
      <p class="lead mt-5 max-w-xl">
        Fixed checklists, uniformed cleaners, no surprises — just results you can see. Scroll to explore what each service covers.
      </p>
    </div>

    <div class="mt-14 grid items-start gap-10 lg:mt-20 lg:grid-cols-[1fr_1.05fr] lg:gap-16">
      <!-- Sticky image stack (desktop) -->
      <div class="svc-sticky hidden lg:block">
        <div class="svc-stage">
          {services.map((s, i) => (
            <div class={`svc-photo ${i === 0 ? 'active' : ''}`} data-i={i}>
              <Image src={imgMap[s.img]} alt={s.name} widths={[600, 900, 1200]} sizes="(min-width:1024px) 40vw, 90vw" quality={80} />
            </div>
          ))}
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-[rgba(6,8,12,0.7)] to-transparent"></div>
        </div>
      </div>

      <!-- Scrollable service list -->
      <div>
        {services.map((s, i) => (
          <article class="svc-item" data-active={i === 0 ? 'true' : 'false'}>
            <!-- Mobile inline photo (sticky stack is desktop-only) -->
            <div class="reveal-img mb-5 overflow-hidden rounded-2xl border border-[var(--color-line)] lg:hidden">
              <Image src={imgMap[s.img]} alt={s.name} widths={[400, 720]} sizes="90vw" quality={78} class="aspect-[4/3] w-full object-cover" />
            </div>
            <div class="flex items-center gap-4">
              <span class="svc-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="h-px flex-1 bg-[var(--color-line)]"></span>
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </span>
            </div>
            <h3 class="mt-5 text-2xl font-semibold text-white sm:text-3xl">{s.name}</h3>
            <p class="mt-1.5 text-sm font-semibold text-[var(--color-accent)]">{s.tag}</p>
            <p class="mt-4 max-w-lg leading-relaxed text-[var(--color-muted-2)]">{s.body}</p>
            <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2">
              {s.points.map((p) => (
                <li class="inline-flex items-center gap-2 text-sm text-[var(--color-text)]">
                  <svg class="text-[var(--color-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  {p}
                </li>
              ))}
            </ul>
            <a href={bookFor(s.name)} target="_blank" rel="noopener" data-cursor="Quote" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-white transition hover:text-[var(--color-accent)]">
              Get a quote for this
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
