---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import heroBg from '../assets/hero-background.jpg';
---

<section id="top" class="relative flex min-h-[100svh] items-center overflow-hidden pt-28 pb-20">
  <!-- Cinematic hero photo (Ken Burns + JS clip-path load wipe) -->
  <div class="hero-photo">
    <Image src={heroBg} alt="A pristine, softly lit modern Australian living space at dusk" widths={[768, 1280, 1920, 2400]} sizes="100vw" loading="eager" fetchpriority="high" quality={82} />
  </div>
  <!-- Legibility scrim + subtle teal glow -->
  <div class="hero-scrim"></div>
  <div class="mesh" aria-hidden="true"></div>

  <div class="container-x relative w-full">
    <div id="heroCopy" class="max-w-3xl">
      <span class="eyebrow rise" style="animation-delay:.05s">Australia-wide · Insured · Bond-back guaranteed</span>

      <h1 class="display-1 mt-6 text-balance rise" style="animation-delay:.15s" id="heroTitle">
        A spotless space,<br /><span class="text-gradient"><em>every single time.</em></span>
      </h1>

      <p class="lead mt-7 max-w-xl rise" style="animation-delay:.35s">
        {site.subtagline}
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3 rise" style="animation-delay:.55s">
        <a href="#quote" data-magnetic data-cursor="Book" class="btn btn-primary">
          <span class="mag-label inline-flex items-center gap-2">
            Get a free quote
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
        <a href="#services" class="btn btn-ghost">See our services</a>
        <span class="pill ml-1 hidden sm:inline-flex"><span class="dot"></span>Same-day quotes</span>
      </div>

      <!-- Trust row -->
      <div class="mt-11 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-[var(--color-text)] rise" style="animation-delay:.7s">
        <span class="inline-flex items-center gap-2">
          <span class="text-lg text-[var(--color-warm)]">★★★★★</span> 4.9 from 300+ reviews
        </span>
        <span class="inline-flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
          Police-checked cleaners
        </span>
        <span class="inline-flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.2"><path d="M20 6 9 17l-5-5"/></svg>
          Fully insured
        </span>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a href="#trust" aria-label="Scroll down" class="scroll-cue absolute bottom-6 left-1/2 -translate-x-1/2 text-[var(--color-muted-2)]">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
  </a>
</section>
