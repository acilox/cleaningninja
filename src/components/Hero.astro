---
import { site } from '../data/site';
---

<section id="top" class="relative flex min-h-[100svh] items-center overflow-hidden pt-28 pb-16">
  <!-- Three.js particle canvas (sits behind everything) -->
  <canvas id="hero-canvas" class="absolute inset-0 -z-10 h-full w-full"></canvas>
  <!-- Depth gradients over the canvas -->
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_0%,rgba(0,212,170,0.14),transparent_70%)]"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-40 bg-gradient-to-t from-[var(--color-bg)] to-transparent"></div>

  <div class="container-x relative w-full">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow rise" style="animation-delay:.05s" id="heroEyebrow">Australia-wide · Insured · Guaranteed</span>

      <h1 class="display-1 mt-5 text-balance rise" style="animation-delay:.15s" id="heroTitle">
        A spotless space,<br /><span class="text-gradient">every single time.</span>
      </h1>

      <p class="lead mx-auto mt-6 max-w-xl rise" style="animation-delay:.35s" id="heroSub">
        {site.subtagline}
      </p>

      <p class="mt-3 text-sm font-medium text-[var(--color-muted)] rise" style="animation-delay:.5s" id="heroPain">
        Still sending customers to a Google listing? Your competition isn’t.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3 rise" style="animation-delay:.6s" id="heroCtas">
        <a href="#quote" data-magnetic class="btn btn-primary">
          Get a free quote
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#services" class="btn btn-ghost">See our services</a>
      </div>

      <!-- Trust row -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-sm text-[var(--color-muted-2)] rise" style="animation-delay:.72s" id="heroTrust">
        <span class="inline-flex items-center gap-2">
          <span class="text-[var(--color-warm)]">★★★★★</span> 4.9 average rating
        </span>
        <span class="inline-flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
          Police-checked cleaners
        </span>
        <span class="inline-flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
          Fully insured
        </span>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a href="#services" aria-label="Scroll to services" class="scroll-cue absolute bottom-6 left-1/2 -translate-x-1/2 text-[var(--color-muted)]">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
  </a>
</section>

<!-- Three.js particle field — self-contained, loaded from CDN. -->
<script is:inline src="https://cdn.jsdelivr.net/npm/three@0.149.0/build/three.min.js" defer></script>
<script is:inline>
  window.addEventListener('load', () => {
    const canvas = document.getElementById('hero-canvas');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Hero text intro is pure CSS (.rise) so the headline never depends on a CDN.
    // This script only powers the optional Three.js particle field behind it.
    if (!canvas || typeof window.THREE === 'undefined' || reduce) return;

    // Pre-check WebGL on a throwaway canvas so we never invoke Three.js (and its
    // internal console errors) on devices where WebGL is blocked/unavailable.
    // The hero keeps its CSS gradient + animated headline, so nothing looks broken.
    const webglOK = (() => {
      try {
        const c = document.createElement('canvas');
        return !!(window.WebGLRenderingContext && (c.getContext('webgl2') || c.getContext('webgl')));
      } catch (e) { return false; }
    })();
    if (!webglOK) { canvas.style.display = 'none'; return; }

    const THREE = window.THREE;

    let renderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    } catch (e) {
      canvas.style.display = 'none';
      return;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, 1, 0.1, 100);
    camera.position.z = 6;

    const COUNT = 90;
    const positions = new Float32Array(COUNT * 3);
    const speeds = new Float32Array(COUNT);
    const spread = 9;
    for (let i = 0; i < COUNT; i++) {
      positions[i * 3] = (Math.random() - 0.5) * spread;
      positions[i * 3 + 1] = (Math.random() - 0.5) * spread;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 4;
      speeds[i] = 0.002 + Math.random() * 0.006;
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));

    // Round, glowing teal sprite via canvas texture.
    const sprite = (() => {
      const c = document.createElement('canvas');
      c.width = c.height = 64;
      const g = c.getContext('2d');
      const grd = g.createRadialGradient(32, 32, 0, 32, 32, 32);
      grd.addColorStop(0, 'rgba(0,212,170,1)');
      grd.addColorStop(0.3, 'rgba(0,212,170,0.6)');
      grd.addColorStop(1, 'rgba(0,212,170,0)');
      g.fillStyle = grd;
      g.fillRect(0, 0, 64, 64);
      return new THREE.CanvasTexture(c);
    })();

    const mat = new THREE.PointsMaterial({
      size: 0.28, map: sprite, transparent: true, depthWrite: false,
      blending: THREE.AdditiveBlending,
    });
    const points = new THREE.Points(geo, mat);
    scene.add(points);

    // Thin connection lines between nearby particles.
    const lineMat = new THREE.LineBasicMaterial({ color: 0x00d4aa, transparent: true, opacity: 0.08 });
    const lineGeo = new THREE.BufferGeometry();
    const lineSegments = new THREE.LineSegments(lineGeo, lineMat);
    scene.add(lineSegments);

    let mouseX = 0, mouseY = 0, camX = 0, camY = 0;
    window.addEventListener('pointermove', (e) => {
      mouseX = (e.clientX / window.innerWidth - 0.5);
      mouseY = (e.clientY / window.innerHeight - 0.5);
    }, { passive: true });

    function resize() {
      const w = canvas.clientWidth, h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    let paused = false;
    document.addEventListener('visibilitychange', () => { paused = document.hidden; });

    function buildLines() {
      const pts = [];
      const p = geo.attributes.position.array;
      const maxDist = 1.5;
      for (let i = 0; i < COUNT; i++) {
        for (let j = i + 1; j < COUNT; j++) {
          const dx = p[i*3]-p[j*3], dy = p[i*3+1]-p[j*3+1], dz = p[i*3+2]-p[j*3+2];
          if (dx*dx + dy*dy + dz*dz < maxDist*maxDist) {
            pts.push(p[i*3], p[i*3+1], p[i*3+2], p[j*3], p[j*3+1], p[j*3+2]);
          }
        }
      }
      lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(pts, 3));
    }

    let frame = 0;
    function animate() {
      requestAnimationFrame(animate);
      if (paused) return;
      const pos = geo.attributes.position.array;
      for (let i = 0; i < COUNT; i++) {
        pos[i * 3 + 1] += speeds[i]; // drift upward like bubbles
        if (pos[i * 3 + 1] > spread / 2) pos[i * 3 + 1] = -spread / 2;
      }
      geo.attributes.position.needsUpdate = true;
      if (frame % 6 === 0) buildLines(); // rebuild lines occasionally (cheap)
      frame++;

      // Gentle mouse parallax (lerped).
      camX += (mouseX * 0.6 - camX) * 0.04;
      camY += (-mouseY * 0.6 - camY) * 0.04;
      camera.position.x = camX;
      camera.position.y = camY;
      camera.lookAt(scene.position);
      points.rotation.z += 0.0004;

      renderer.render(scene, camera);
    }
    animate();
  });
</script>
