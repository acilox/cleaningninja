---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import ovenBefore from '../assets/ba-oven-before.jpg';
import ovenAfter from '../assets/ba-oven-after.jpg';

const trust = ['Police-checked', 'Fully insured', 'Bond-back guarantee'];
---

<section id="top" class="hero relative overflow-hidden">
  <div class="mesh" aria-hidden="true"></div>
  <span class="hero-orb" aria-hidden="true"></span>

  <!-- Editorial content (left; sits on the solid dark canvas) -->
  <div class="container-x relative z-10 flex items-center pt-32 pb-12 lg:min-h-[100svh] lg:pt-24 lg:pb-24">
    <div id="heroCopy" class="max-w-xl">
      <span class="hero-pill rise" style="animation-delay:.05s">
        <span class="dot"></span>
        <span class="text-[var(--color-warm)]">★★★★★</span>
        Rated 4.9 · Bond-back guaranteed
      </span>

      <h1 id="heroTitle" class="hero-title mt-6 rise" style="animation-delay:.15s">
        A spotless space,<br /><span class="text-gradient"><em>every single time.</em></span>
      </h1>

      <p class="lead mt-6 rise" style="animation-delay:.32s">
        Drag the photo&nbsp;→&nbsp; that’s one of our real end-of-lease cleans. Bond-standard
        results from police-checked crews, quoted the same day.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3 rise" style="animation-delay:.46s">
        <a href="#quote" data-magnetic data-cursor="Book" class="btn btn-primary btn-lg">
          <span class="mag-label inline-flex items-center gap-2">
            Get a free quote
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
        <a href="#results" data-cursor="See" class="btn btn-ghost btn-lg">See more results</a>
      </div>

      <ul class="mt-9 flex flex-wrap gap-x-6 gap-y-2.5 rise" style="animation-delay:.58s">
        {trust.map((t) => (
          <li class="inline-flex items-center gap-2 text-sm text-[var(--color-text)]">
            <svg class="text-[var(--color-accent)]" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            {t}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- The hook: a full-height, auto-sweeping, draggable before/after -->
  <div class="hero-visual2 relative mx-5 mb-6 h-[56svh] overflow-hidden rounded-2xl border border-[var(--color-line)] lg:absolute lg:inset-y-0 lg:right-0 lg:m-0 lg:h-auto lg:w-[53%] lg:rounded-none lg:border-0">
    <div class="ba ba--hero" style="--pos:50%" data-cursor="Drag">
      <Image class="ba-before" src={ovenBefore} alt="A grimy, grease-caked oven — before CleaningNinja" widths={[600, 900, 1300, 1700]} sizes="(min-width:1024px) 55vw, 100vw" loading="eager" fetchpriority="high" quality={80} />
      <Image class="ba-after" src={ovenAfter} alt="The same oven, spotless and gleaming — after CleaningNinja" widths={[600, 900, 1300, 1700]} sizes="(min-width:1024px) 55vw, 100vw" loading="eager" quality={80} />
      <span class="ba-label ba-label--before">Before</span>
      <span class="ba-label ba-label--after">After</span>
      <div class="ba-divider"></div>
      <div
        class="ba-handle"
        role="slider"
        tabindex="0"
        aria-label="Drag to reveal the cleaned oven"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/></svg>
      </div>
    </div>
    <!-- seam fade into the dark canvas (desktop) -->
    <div class="hero-fade" aria-hidden="true"></div>
    <!-- caption -->
    <p class="hero-cap">A real end-of-lease oven clean — one visit.</p>
  </div>

  <!-- Scroll cue -->
  <a href="#trust" aria-label="Scroll down" class="scroll-cue absolute bottom-6 left-6 hidden text-[var(--color-muted-2)] lg:block">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
  </a>
</section>
