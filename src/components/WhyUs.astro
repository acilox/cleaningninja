---
import { whyUs } from '../data/site';
const dirs = ['data-reveal-left', 'data-reveal', 'data-reveal-right'];
---

<section class="section bg-[var(--color-bg-2)]">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Why CleaningNinja</span>
      <h2 class="display-2 mt-4">Cleaning you never have to think about</h2>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {whyUs.map((w, i) => (
        <div class="card p-8" {...{ [dirs[i]]: true }}>
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={w.icon} />
          </div>
          <h3 class="mt-6 text-xl font-bold text-white">{w.title}</h3>
          <p class="mt-3 leading-relaxed text-[var(--color-muted-2)]">{w.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
