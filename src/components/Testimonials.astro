---
import { testimonials } from '../data/site';
---

<section id="reviews" class="section">
  <div class="glow-spot"></div>
  <div class="container-x relative">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Loved by locals</span>
      <h2 class="display-2 mt-4" data-split>Real results, <em>real reviews</em></h2>
      <div class="mt-4 flex items-center justify-center gap-2 text-[var(--color-muted-2)]">
        <span class="text-lg text-[var(--color-warm)]">★★★★★</span>
        <span class="text-sm">4.9 / 5 from 300+ happy customers</span>
      </div>
    </div>

    <!-- Seamless, pause-on-hover marquee of reviews (reduced-motion → wrapped grid) -->
    <div class="reviews-marquee mt-14" data-reveal>
      <div class="reviews-track">
        {[...testimonials, ...testimonials].map((t, i) => (
          <figure class={`review-card card flex flex-col p-6 ${i >= testimonials.length ? 'review-dup' : ''}`} aria-hidden={i >= testimonials.length ? 'true' : undefined}>
            <div class="flex items-center justify-between">
              <div class="text-[var(--color-warm)]" aria-label={`${t.rating} out of 5 stars`}>{'★'.repeat(t.rating)}</div>
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--color-line)" stroke-width="1.5"><path d="M10 11H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h1a1 1 0 0 1 1 1v3M20 11h-4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h1a1 1 0 0 1 1 1v3"/></svg>
            </div>
            <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-[var(--color-text)]">“{t.quote}”</blockquote>
            <figcaption class="mt-5 border-t border-[var(--color-line)] pt-4">
              <p class="text-sm font-semibold text-white">{t.name}</p>
              <p class="text-xs text-[var(--color-muted)]">{t.where} · {t.date}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>
